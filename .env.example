# HTBF local environment (copy to .env.local — never commit real secrets)

# Supabase (required for Prayer tests against a dev project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Playwright Prayer harness (development accounts only — placeholder values)
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3492
PLAYWRIGHT_OWNER_EMAIL=owner-dev@example.com
PLAYWRIGHT_OWNER_PASSWORD=replace-with-dev-password
PLAYWRIGHT_RESPONDER_EMAIL=responder-dev@example.com
PLAYWRIGHT_RESPONDER_PASSWORD=replace-with-dev-password
PLAYWRIGHT_THIRD_USER_EMAIL=third-dev@example.com
PLAYWRIGHT_THIRD_USER_PASSWORD=replace-with-dev-password

# Optional: admin account for automated moderation-guard tests
PLAYWRIGHT_ADMIN_EMAIL=admin-dev@example.com
PLAYWRIGHT_ADMIN_PASSWORD=replace-with-dev-password
