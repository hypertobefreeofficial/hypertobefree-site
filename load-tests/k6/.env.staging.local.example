# Copy to load-tests/k6/.env.staging.local (gitignored — never commit)
# Gate A local-staging smoke — htbf-staging Supabase branch only

HTBF_LOAD_TEST_ENV=local-staging
HTBF_BASE_URL=http://127.0.0.1:3100
HTBF_LOCAL_TEST_PORT=3100

# Generated Supabase project reference for the htbf-staging branch (NOT the display name)
HTBF_STAGING_PROJECT_REF=ACTUAL_STAGING_PROJECT_REF
HTBF_REQUIRE_STAGING_REF=1

# htbf-staging Supabase branch URL — hostname must exactly match HTBF_STAGING_PROJECT_REF.supabase.co
HTBF_SUPABASE_URL=https://ACTUAL_STAGING_PROJECT_REF.supabase.co
HTBF_SUPABASE_ANON_KEY=

# Required for seed/cleanup scripts only — never commit
HTBF_SUPABASE_SERVICE_ROLE_KEY=

# Next.js aliases for the local production build (must point to htbf-staging only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Smoke run defaults
HTBF_TEST_USER_POOL_FILE=./load-tests/k6/fixtures/users.pool.local.csv
HTBF_ALLOW_MUTATIONS=0
HTBF_ABORT_ON_ERROR=1

# Cleanup defaults to dry-run; set HTBF_CLEANUP_DRY_RUN=0 and HTBF_CONFIRM_CLEANUP=1 to delete
